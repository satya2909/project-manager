# Copy to .env and fill in real values. Never commit the real .env file.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Frontend origin(s) allowed to call the API with credentials (no trailing
# slash). Comma-separated for multiple origins, e.g. staging + production.
# Required in production.
CORS_ORIGIN=http://localhost:5173

# Base URL of the deployed frontend, used to build links in emails
# (verification, invite, password reset). Required in production.
CLIENT_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/project-management

# ─── Auth tokens ──────────────────────────────────────────────────────────────
# Use long random strings in production, e.g. `openssl rand -hex 64`.
ACCESS_TOKEN_SECRET=changeme-access-secret
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=changeme-refresh-secret
REFRESH_TOKEN_EXPIRY=7d

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Required in production — used for email verification, invites, and password
# reset. Any SMTP provider works (Gmail, SendGrid, Mailtrap, Resend, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=no-reply@example.com
